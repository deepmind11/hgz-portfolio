---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";

const skills = {
  "Pipeline engineering": ["Nextflow", "Snakemake", "workflow orchestration", "HPC / Slurm"],
  "Programming": ["Python", "R", "SQL", "Bash", "Groovy (Nextflow DSL)"],
  "Cloud / infra": ["AWS S3", "AWS Batch", "Lambda", "Fargate", "EventBridge", "ECR", "Bedrock", "Terraform", "Docker"],
  "Bioinformatics": ["Samtools", "BEDtools", "GATK", "BCFtools", "VarDict", "Scanpy", "Picard", "PLINK", "DESeq", "PySAM"],
  "Assay tech": ["Hybrid capture with UMI", "bisulfite sequencing", "multiplex PCR", "cell-free DNA", "ChIP-seq", "DNase-seq"],
  "Data science": ["Pandas", "NumPy", "Scikit-learn", "Plotly", "Matplotlib", "Tidyverse", "Jupyter"],
  "AI / ML": ["Multi-agent systems", "LangGraph", "MCP", "AWS Bedrock", "Claude", "OpenRouter"],
  "Languages": ["English", "Bengali", "Hindi", "Spanish"],
};
---

<BaseLayout
  title="About"
  description="Harshit Ghosh — building at the intersection of biology and AI."
  ogImage="/og/og-about.png"
>
  <section class="container-narrow pt-16 pb-12">
    <h1 class="font-bold tracking-tight mb-6">About</h1>

    <div class="prose">
      <p>
        Hi, I'm Harshit. I'm building at the intersection of biology and AI.
      </p>

      <p>
        Currently I'm interested in deep learning for biology, which is about
        building new deep learning architectures and new foundation models for
        understanding proteins, genomic data, gene regulation, and things like
        that.
      </p>

      <p>
        Second, I'm interested in building agentic systems that rely on these
        deep learning models to reason in the real world.
      </p>
    </div>
  </section>

  <section class="container-narrow pb-12">
    <h2 class="font-semibold tracking-tight mb-6 pt-8" style="border-top: 1px solid var(--color-border);">
      Education
    </h2>
    <ul class="space-y-2 text-base" style="color: var(--color-fg);">
      <li>Columbia University</li>
      <li>Indian Institute of Technology, Kanpur</li>
    </ul>
  </section>

  <section class="container-narrow pb-12">
    <h2 class="font-semibold tracking-tight mb-8 pt-8" style="border-top: 1px solid var(--color-border);">
      Technical skills
    </h2>

    <div class="space-y-5">
      {Object.entries(skills).map(([category, items]) => (
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: var(--color-fg-muted);">
            {category}
          </h3>
          <div class="flex flex-wrap gap-1.5">
            {items.map((s) => <span class="badge">{s}</span>)}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="container-narrow pb-16">
    <h2 class="font-semibold tracking-tight mb-6 pt-8" style="border-top: 1px solid var(--color-border);">
      Publication
    </h2>
    <div class="prose">
      <p>
        <strong>Record High Magnetic Anisotropy in Three-Coordinate Mn<sup>III</sup> and Cr<sup>II</sup> Complexes: A Theoretical Perspective.</strong>
        <em>Inorganic Chemistry</em>, ACS.
        <a href="https://doi.org/10.1021/acs.inorgchem.1c00978" target="_blank" rel="noopener">DOI: 10.1021/acs.inorgchem.1c00978</a>
      </p>
    </div>
  </section>
</BaseLayout>
