---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";

const experience = [
  {
    role: "Bioinformatics Associate, Oncology",
    company: "BillionToOne Inc",
    location: "Menlo Park, CA",
    dates: "Nov 2024 — Mar 2026",
    highlights: [
      "Built an automated variant validation system using PySAM and BAM-level alignment analysis to verify VarDict indel calls in the NorthStar Select Assay, catching 100% of false positive calls without affecting assay sensitivity.",
      "Engineered a sample dwell-check monitoring system on AWS (Lambda, EventBridge, Terraform) tracking 600+ samples/day across BI databases and LabIt LIMS, catching 15-20 at-risk samples per week.",
      "Built an agentic AI sample-query chatbot on AWS Bedrock that lets QA, MSLs, and Variant Interpretation teams query sample status in natural language and generate diagnostic hypotheses.",
      "Engineered an automated NP-hard plot labeling system using constrained optimization that the team believed could not be automated. Eliminated manual plot review from operational workflows.",
      "Optimized Nextflow-based production pipelines processing 2,000+ patient samples/week on AWS for the NorthStar Response Assay (multiplex PCR + bisulfite sequencing).",
    ],
  },
  {
    role: "Computational Biologist",
    company: "Columbia University",
    location: "New York, NY",
    dates: "Jan 2023 — Oct 2024",
    highlights: [
      "Configured PyProBound (PyTorch-based binding model) to analyze 20-25 transcription factors across hundreds of ENCODE ChIP-seq datasets, identifying a 20% difference in binding preferences across chromosomes for certain TFs.",
      "Built end-to-end Snakemake pipelines automating FASTQ QC, alignment, peak calling, post-processing, and downstream PyProBound analysis. Reduced project management time by 90%.",
      "Inferred DNA binding preferences of DNaseI through statistical analysis of two million DNase-seq fragments.",
      "Achieved 100% CPU utilization on an HPC cluster by parallelizing genomics workloads across 50+ threads, reducing per-job runtimes from hours to minutes.",
    ],
  },
  {
    role: "AI Biology Trainer",
    company: "Outlier (Scale AI)",
    location: "Remote",
    dates: "Jan 2024 — Sep 2024",
    highlights: [
      "Designed biology-domain prompts across molecular biology, genomics, and bioinformatics for RLHF training pipelines at Scale AI.",
      "Rated LLM-generated responses for scientific accuracy, reasoning quality, and prompt-following behavior, contributing to foundation model alignment.",
      "Identified and flagged scientific hallucinations and citation fabrications across hundreds of biology-domain interactions.",
    ],
  },
  {
    role: "Investment Analyst, Antibody Drug Conjugates",
    company: "Blackstone",
    location: "New York, NY",
    dates: "Jan 2023 — May 2023",
    highlights: [
      "Identified the top five ADCs by market share through comprehensive oncology market analysis.",
      "Developed an evaluation framework for emerging ADCs through case studies of successful and failed candidates.",
      "Shortlisted three investments with multi-billion dollar market potential by analyzing clinical trial data of 100+ late-stage ADCs.",
      "Presented analysis to Blackstone executives.",
    ],
  },
  {
    role: "Data Scientist",
    company: "Standard Chartered Bank",
    location: "Bangalore, India",
    dates: "Jul 2019 — Jul 2021",
    highlights: [
      "Built a prescriptive ML model in R that identified new 7-figure revenue opportunities for sales teams.",
      "Pooled data from legacy systems into a central data warehouse to unify analytical capabilities across five business areas.",
      "Followed Agile Scrum framework for software development.",
    ],
  },
];

const education = [
  {
    school: "Columbia University",
    degree: "MA in Biotechnology",
    location: "New York, NY",
    dates: "2022 — 2023",
    detail: "GPA 3.80 / 4.0",
  },
  {
    school: "Indian Institute of Technology, Kanpur",
    degree: "BS in Chemistry",
    location: "Kanpur, India",
    dates: "2015 — 2019",
    detail: "INSPIRE Scholarship recipient",
  },
];

const skills = {
  "Pipeline engineering": ["Nextflow", "Snakemake", "workflow orchestration", "HPC / Slurm"],
  "Programming": ["Python", "R", "SQL", "Bash", "Groovy (Nextflow DSL)"],
  "Cloud / infra": ["AWS S3", "AWS Batch", "Lambda", "Fargate", "EventBridge", "ECR", "Bedrock", "Terraform", "Docker"],
  "Bioinformatics": ["Samtools", "BEDtools", "GATK", "BCFtools", "VarDict", "Scanpy", "Picard", "PLINK", "DESeq", "PySAM"],
  "Assay tech": ["Hybrid capture with UMI", "bisulfite sequencing", "multiplex PCR", "cell-free DNA", "ChIP-seq", "DNase-seq"],
  "Data science": ["Pandas", "NumPy", "Scikit-learn", "Plotly", "Matplotlib", "Tidyverse", "Jupyter"],
  "AI / ML": ["Multi-agent systems", "LangGraph", "MCP", "AWS Bedrock", "Claude", "OpenRouter", "Langfuse"],
  "Regulatory": ["CAP/CLIA", "NYSDOH"],
  "Languages": ["English (native)", "Bengali (native)", "Hindi (native)", "Spanish (professional)"],
};
---

<BaseLayout
  title="About"
  description="Bioinformatics engineer with three years of production experience at a CAP/CLIA oncology lab, an MA from Columbia, and an active build pipeline of multi-agent AI systems for biotech."
>
  <section class="container-narrow pt-16 pb-12">
    <h1 class="font-bold tracking-tight mb-6">About</h1>

    <div class="prose">
      <p>
        I'm Harshit. I build bioinformatics infrastructure and multi-agent AI systems
        for biotech and healthcare. Most recently, I was a Bioinformatics Associate at
        BillionToOne, a CAP/CLIA molecular diagnostics company in Menlo Park, where I
        worked on the NorthStar Select and Response oncology assays.
      </p>

      <p>
        Before BillionToOne I spent two years as a Computational Biologist at Columbia,
        analyzing transcription factor binding preferences with PyProBound and shipping
        Snakemake pipelines that automated the full ChIP-seq workflow. I got my MA in
        Biotechnology there in 2023 with a 3.80 GPA. My undergrad is a BS in Chemistry
        from IIT Kanpur, where I was an INSPIRE Scholarship recipient and co-authored
        a paper in Inorganic Chemistry on magnetic anisotropy in three-coordinate
        Mn(III) and Cr(II) complexes.
      </p>

      <p>
        Right now I'm focused on the open-source multi-agent systems you'll find on
        the projects page — VariantAgent (clinical variant interpretation),
        CovalentAgent (covalent drug design), Constella (Polaris-style voice agent
        with native English-Spanish code-switching), and ClinicOps Copilot
        (FDE day-one artifact for healthcare AI deployments). I'm targeting
        bioinformatics + AI engineering roles, Forward Deployed Engineer roles at
        healthcare AI startups, and computational biology positions where multi-agent
        infrastructure is part of the job.
      </p>

      <p>
        I'm based in Mountain View, CA. I hold an H-1B that's transferable. You can
        reach me at <a href="mailto:harshitghosh@gmail.com">harshitghosh@gmail.com</a>
        or on <a href="https://linkedin.com/in/harshit-ghosh" target="_blank" rel="noopener">LinkedIn</a>.
      </p>
    </div>
  </section>

  <section class="container-narrow pb-12">
    <h2 class="font-semibold tracking-tight mb-8 pt-8" style="border-top: 1px solid var(--color-border);">
      Experience
    </h2>

    <div class="space-y-10">
      {experience.map((job) => (
        <div>
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-1">
            <h3 class="text-lg font-semibold" style="color: var(--color-fg);">
              {job.role}
            </h3>
            <span class="text-xs font-mono" style="color: var(--color-fg-subtle);">
              {job.dates}
            </span>
          </div>
          <p class="text-sm mb-3" style="color: var(--color-accent);">
            {job.company} · {job.location}
          </p>
          <ul class="space-y-2 text-sm leading-relaxed" style="color: var(--color-fg-muted);">
            {job.highlights.map((h) => (
              <li class="flex gap-2">
                <span style="color: var(--color-accent);">▸</span>
                <span>{h}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="container-narrow pb-12">
    <h2 class="font-semibold tracking-tight mb-8 pt-8" style="border-top: 1px solid var(--color-border);">
      Education
    </h2>

    <div class="space-y-6">
      {education.map((edu) => (
        <div>
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-1">
            <h3 class="text-lg font-semibold" style="color: var(--color-fg);">
              {edu.school}
            </h3>
            <span class="text-xs font-mono" style="color: var(--color-fg-subtle);">
              {edu.dates}
            </span>
          </div>
          <p class="text-sm mb-1" style="color: var(--color-accent);">
            {edu.degree} · {edu.location}
          </p>
          <p class="text-sm" style="color: var(--color-fg-muted);">{edu.detail}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="container-narrow pb-12">
    <h2 class="font-semibold tracking-tight mb-8 pt-8" style="border-top: 1px solid var(--color-border);">
      Technical skills
    </h2>

    <div class="space-y-5">
      {Object.entries(skills).map(([category, items]) => (
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: var(--color-fg-subtle);">
            {category}
          </h3>
          <div class="flex flex-wrap gap-1.5">
            {items.map((s) => <span class="badge">{s}</span>)}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="container-narrow pb-12">
    <h2 class="font-semibold tracking-tight mb-6 pt-8" style="border-top: 1px solid var(--color-border);">
      Publication
    </h2>

    <div class="prose">
      <p>
        <strong>Record High Magnetic Anisotropy in Three-Coordinate Mn<sup>III</sup> and Cr<sup>II</sup> Complexes: A Theoretical Perspective.</strong>
        <em>Inorganic Chemistry</em>, ACS.
        <a href="https://doi.org/10.1021/acs.inorgchem.1c00978" target="_blank" rel="noopener">DOI: 10.1021/acs.inorgchem.1c00978</a>
      </p>
    </div>
  </section>
</BaseLayout>
