---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import OpsDashboard from "../components/OpsDashboard";
---

<BaseLayout
  title="Ops"
  description="Live observability for the Ask Harshit chatbot and the live demos."
  ogImage="/og/og-default.png"
>
  <section class="container-narrow pt-16 pb-16">
    <h1 class="font-bold tracking-tight mb-4">Ops</h1>
    <p class="text-lg leading-relaxed mb-10" style="color: var(--color-fg-muted);">
      Live numbers from the chatbot. Message volume, token spend, and latency
      percentiles, queried directly from D1 every sixty seconds. No PII. No
      tracking pixels. Just the things I think are interesting to watch.
    </p>

    <OpsDashboard client:load />
  </section>
</BaseLayout>
