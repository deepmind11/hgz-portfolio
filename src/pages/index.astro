---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Harshit Ghosh",
  "url": "https://hgz-portfolio.harshitghosh.workers.dev/",
  "description":
    "Portfolio of Harshit Ghosh. Four open-source multi-agent AI systems for genomics, drug discovery, and clinical operations. Every project runs live in the browser.",
  "author": {
    "@type": "Person",
    "name": "Harshit Ghosh",
  },
  "inLanguage": "en-US",
};
---

<BaseLayout title="Harshit Ghosh" jsonLd={websiteSchema} ogImage="/og/og-default.png">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 grid-bg opacity-40"></div>
    <div class="container-prose relative pt-20 pb-16 sm:pt-28 sm:pb-24">
      <div class="max-w-3xl">
        <h1 class="font-bold tracking-tight mb-6">
          <span style="color: var(--color-fg);">I build </span>
          <span style="color: var(--color-accent);">multi-agent AI systems</span>
          <span style="color: var(--color-fg);"> for genomics, drug discovery, and clinical operations.</span>
        </h1>

        <p class="text-lg leading-relaxed mb-8 max-w-2xl" style="color: var(--color-fg-muted);">
          Four open-source projects below. Each one runs live in your browser. Code is on GitHub.
        </p>

        <div class="flex flex-wrap gap-3">
          <a href="/projects" class="btn btn-primary">
            See the projects
            <span>→</span>
          </a>
          <a href="/about" class="btn btn-secondary">About</a>
        </div>

        <div class="mt-12 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm font-mono" style="color: var(--color-fg-subtle);">
          <span class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full" style="background-color: var(--color-accent);"></span>
            Mountain View, CA
          </span>
          <span>·</span>
          <span>Columbia MA Biotech</span>
          <span>·</span>
          <span>IIT Kanpur BS Chemistry</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured projects -->
  <section class="container-prose py-16">
    <div class="flex items-end justify-between mb-10">
      <div>
        <h2 class="font-semibold tracking-tight mb-2">Featured projects</h2>
        <p style="color: var(--color-fg-muted);">
          Four projects, all live, all open source.
        </p>
      </div>
      <a href="/projects" class="link-accent text-sm font-medium hidden sm:inline">
        View all →
      </a>
    </div>

    <div class="grid gap-5 sm:grid-cols-2">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</BaseLayout>
