---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order);

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Projects",
  "url": "https://hgz-portfolio.harshitghosh.workers.dev/projects/",
  "description":
    "Four open-source multi-agent AI systems for genomics, drug discovery, and clinical operations.",
  "hasPart": projects.map((p) => ({
    "@type": "SoftwareSourceCode",
    "name": p.data.title,
    "description": p.data.description,
    "url": `https://hgz-portfolio.harshitghosh.workers.dev/projects/${p.data.slug}/`,
    "codeRepository": p.data.github,
  })),
};
---

<BaseLayout
  title="Projects"
  description="Four open-source multi-agent AI systems for genomics, drug discovery, and clinical operations."
  jsonLd={collectionSchema}
  ogImage="/og/og-projects.png"
>
  <section class="container-prose pt-16 pb-12">
    <div class="max-w-2xl">
      <h1 class="font-bold tracking-tight mb-4">Projects</h1>
      <p class="text-lg leading-relaxed" style="color: var(--color-fg-muted);">
        Multi-agent systems I've shipped or am actively building. Every project is open
        source on GitHub. Each one targets a specific gap in the bioinformatics or
        clinical AI ecosystem and ships with an eval harness, a CLI, and a deploy story.
      </p>
    </div>
  </section>

  <section class="container-prose pb-16">
    <div class="grid gap-5 sm:grid-cols-2">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</BaseLayout>
