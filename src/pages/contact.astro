---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";

const channels = [
  {
    label: "Email",
    value: "harshitghosh@gmail.com",
    href: "mailto:harshitghosh@gmail.com",
  },
  {
    label: "LinkedIn",
    value: "linkedin.com/in/harshit-ghosh",
    href: "https://linkedin.com/in/harshit-ghosh",
  },
  {
    label: "GitHub",
    value: "github.com/deepmind11",
    href: "https://github.com/deepmind11",
  },
];
---

<BaseLayout
  title="Contact"
  description="How to reach Harshit Ghosh."
  ogImage="/og/og-default.png"
>
  <section class="container-narrow pt-16 pb-16">
    <h1 class="font-bold tracking-tight mb-6">Contact</h1>

    <p class="text-lg leading-relaxed mb-10" style="color: var(--color-fg-muted);">
      Email is the fastest. I read everything.
    </p>

    <div class="space-y-4">
      {channels.map((c) => (
        <a
          href={c.href}
          target={c.href.startsWith("http") ? "_blank" : undefined}
          rel="noopener"
          class="surface surface-hover block p-5 group"
        >
          <div class="flex items-baseline justify-between gap-3 mb-1">
            <span class="text-xs font-mono uppercase tracking-wider" style="color: var(--color-fg-muted);">
              {c.label}
            </span>
            <span class="text-xs transition-transform group-hover:translate-x-1" style="color: var(--color-accent);">
              →
            </span>
          </div>
          <div class="font-mono" style="color: var(--color-accent);">{c.value}</div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
