---
const year = new Date().getFullYear();
---

<footer
  class="mt-32 py-12"
  style="border-top: 1px solid var(--color-border);"
>
  <div class="container-prose grid gap-8 sm:grid-cols-3">
    <div>
      <div class="flex items-center gap-2 mb-3">
        <span
          class="flex items-center justify-center w-8 h-8 rounded-md font-mono font-bold text-xs"
          style="background-color: var(--color-accent); color: var(--color-bg);"
        >
          hg
        </span>
        <span class="font-semibold">Harshit Ghosh</span>
      </div>
      <p class="text-sm" style="color: var(--color-fg-muted);">
        Bioinformatics engineer building multi-agent AI systems for biotech and healthcare.
      </p>
    </div>

    <div>
      <h4 class="text-xs font-semibold uppercase tracking-wider mb-3" style="color: var(--color-fg-subtle);">
        Navigate
      </h4>
      <ul class="space-y-2 text-sm">
        <li><a href="/projects" class="hover:underline" style="color: var(--color-fg-muted);">Projects</a></li>
        <li><a href="/about" class="hover:underline" style="color: var(--color-fg-muted);">About</a></li>
        <li><a href="/blog" class="hover:underline" style="color: var(--color-fg-muted);">Blog</a></li>
        <li><a href="/contact" class="hover:underline" style="color: var(--color-fg-muted);">Contact</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-xs font-semibold uppercase tracking-wider mb-3" style="color: var(--color-fg-subtle);">
        Elsewhere
      </h4>
      <ul class="space-y-2 text-sm">
        <li>
          <a href="https://github.com/deepmind11" target="_blank" rel="noopener" class="hover:underline" style="color: var(--color-fg-muted);">
            GitHub →
          </a>
        </li>
        <li>
          <a href="https://linkedin.com/in/harshit-ghosh" target="_blank" rel="noopener" class="hover:underline" style="color: var(--color-fg-muted);">
            LinkedIn →
          </a>
        </li>
        <li>
          <a href="mailto:harshitghosh@gmail.com" class="hover:underline" style="color: var(--color-fg-muted);">
            Email →
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="container-prose mt-10 pt-6" style="border-top: 1px solid var(--color-border);">
    <div class="flex flex-col sm:flex-row sm:justify-between gap-2 text-xs" style="color: var(--color-fg-subtle);">
      <span>© {year} Harshit Ghosh.</span>
      <span class="font-mono">
        Built with Astro · Hosted on Cloudflare Pages · Source on
        <a href="https://github.com/deepmind11/hgz-portfolio" class="hover:underline" style="color: var(--color-accent);">GitHub</a>
      </span>
    </div>
  </div>
</footer>
