---
const links = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
  { href: "/about", label: "About" },
  { href: "/blog", label: "Blog" },
  { href: "/contact", label: "Contact" },
];

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-40 backdrop-blur-xl"
  style="background-color: color-mix(in oklch, var(--color-bg) 85%, transparent); border-bottom: 1px solid var(--color-border);"
>
  <nav class="container-prose flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-2 group">
      <span
        class="flex items-center justify-center w-9 h-9 rounded-lg font-mono font-bold text-sm transition-all"
        style="background-color: var(--color-accent); color: var(--color-bg);"
      >
        hg
      </span>
      <span class="font-semibold tracking-tight hidden sm:inline">Harshit Ghosh</span>
    </a>

    <ul class="flex items-center gap-1 sm:gap-2">
      {links.map((link) => {
        const isActive =
          link.href === "/"
            ? currentPath === "/"
            : currentPath.startsWith(link.href);
        return (
          <li>
            <a
              href={link.href}
              class="px-3 py-2 rounded-md text-sm font-medium transition-colors"
              style={isActive
                ? "color: var(--color-accent); background-color: color-mix(in oklch, var(--color-accent) 12%, transparent);"
                : "color: var(--color-fg-muted);"}
              onmouseover={!isActive ? "this.style.color='var(--color-fg)'" : undefined}
              onmouseout={!isActive ? "this.style.color='var(--color-fg-muted)'" : undefined}
            >
              {link.label}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</header>
